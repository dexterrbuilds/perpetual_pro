# Copy to .env and fill in secrets (never commit .env)

# Exchange API (optional — public market data works without keys)
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_PASSWORD=

# CryptoPanic news API token (optional)
CRYPTOPANIC_TOKEN=

# Override default exchange: binanceusdm | bybit | okx | bitget
PERP_EXCHANGE=binanceusdm

# Simulated capital for position sizing (default 1000)
SIMULATED_CAPITAL=1000
RISK_PER_TRADE_PCT=1.0

# Streamlit web app (optional)
STREAMLIT_PASSWORD=
BACKEND_URL=http://127.0.0.1:8000

# Telegram high-confidence alerts (REQUIRED for scheduled scans — never commit real values)
# Create a bot via @BotFather, then add the bot to your chat and get chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Secures POST /telegram/test; use a long random value in deployed environments.
TELEGRAM_TEST_KEY=
# Optional: TELEGRAM_ENABLED=0 to force-disable even when credentials are set
# TELEGRAM_ENABLED=1
# Scheduler starts inside the FastAPI process by default; set 0 to disable.
# SCHEDULER_ENABLED=1

# Free LLM narratives (optional — local fallback if unset)
# GROQ_API_KEY=
# GEMINI_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# GEMINI_MODEL=gemini-2.0-flash

# Tesseract binary path if not on PATH
# TESSERACT_CMD=/opt/homebrew/bin/tesseract

# Ollama local vision (optional)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llava
